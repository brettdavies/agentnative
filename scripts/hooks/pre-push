#!/usr/bin/env bash
# SPDX-License-Identifier: MIT OR Apache-2.0
#
# Pre-push hook — enforces markdown hygiene and principle-frontmatter
# validity before publishing.
#
# Activation (run once after clone):
#   git config core.hooksPath scripts/hooks
#
# Pipeline:
#   1. md-wrap --check      — same wrapper the Claude Code PostToolUse
#                             hook runs, in check-only mode. Fails if
#                             any committed `.md` file would reflow.
#   2. markdownlint-cli2    — auto-discovers `.markdownlint-cli2.yaml`
#                             in the repo root (same config the editor
#                             hook uses). Fails on any lint violation.
#   3. check-links.mjs      — validates every relative `[text](path)`
#                             link in committed markdown resolves on
#                             disk.
#   4. validate-principles  — principle-frontmatter schema, ID
#                             uniqueness, and bullet-count parity.
#   5. test-validate-principles — fixture regression tests for the
#                             validator itself.
#   5b. check-last-revised   — enforces the `last-revised` discipline
#                             documented in principles/AGENTS.md: any
#                             frontmatter mutation (other than the date
#                             itself) requires a `last-revised` bump.
#                             Compares HEAD against $BASE_REF (default
#                             origin/dev). Skipped silently when the
#                             base ref is not available locally. Rerun
#                             `node scripts/check-last-revised.mjs --fix`
#                             to auto-stamp today's date on violators.
#   5c. test-check-last-revised — regression tests for the date checker.
#   6. check-release-version — semver check scoped to `release/*`
#                             branches. No-ops on non-release branches.
#                             Enforces X.Y.Z format, strict-monotonic
#                             bump vs origin/main, tag-not-already-used,
#                             and VERSION-must-bump when principles
#                             changed. See scripts/check-release-version.sh.
#   7. generate-pack-readme   — drift check on styles/<Pack>/README.md
#                             against the pack's *.yml (refuses push if
#                             a pack YAML changed without rerunning the
#                             generator).
#   8. shellcheck             — lints every tracked `*.sh` plus everything
#                             under scripts/hooks/ at --severity=warning.
#                             Catches real bugs (unused vars, quoting,
#                             missing exits) while ignoring info/style
#                             noise. Skipped with a one-line note when the
#                             linter is not installed.
#   9. prose-check            — Vale (Brand + Spec + write-good +
#                             proselint) plus LanguageTool when reachable.
#                             Vale errors and category-whitelisted LT
#                             matches block; LT-unreachable falls back to
#                             Vale-only with a notice.
#
# Branch deletions (`git push origin --delete <branch>`) short-circuit
# at the top — the hook reads the push protocol from stdin to detect
# this, so stages 7 and 9 redirect their child stdin to /dev/null
# so they don't fight for protocol bytes.
#
# Working-tree clean precondition: the pipeline below scans the working
# tree, but only committed changes are pushed. A dirty tree could pass
# the gate while pushing different (unsanitized) commits. The hook
# refuses to run if `git diff-index --quiet HEAD --` reports tracked
# changes; untracked files (e.g. vale-synced rule packs) are fine.
#
# js-yaml is installed on demand into the repo's node_modules/ (gitignored).
# If it is already present, install is skipped — subsequent pushes are fast.

set -euo pipefail

# Skip the hook for branch deletions (`git push origin --delete <branch>`),
# which arrive with sha=0000... on stdin from the hook protocol.
deleting_only=true
while read -r local_ref local_sha _remote_ref remote_sha; do
  : "$local_ref" "$local_sha" "$_remote_ref" "$remote_sha"
  if [[ "$local_sha" != "0000000000000000000000000000000000000000" ]]; then
    deleting_only=false
  fi
done
if $deleting_only; then
  exit 0
fi

cd "$(git rev-parse --show-toplevel)"

# Refuse to run if the working tree has uncommitted changes to tracked
# files. The downstream stages (md-wrap, markdownlint, prose-check, etc.)
# scan the working tree, but only committed changes are pushed — so a
# passing gate against a dirty tree does not imply the pushed commits
# pass. Better to fail loudly here than to ship unsanitized commits
# under a green gate. Untracked files are OK (vale-synced packs and the
# like).
if ! git diff-index --quiet HEAD --; then
  echo "FAILED: working tree has uncommitted changes to tracked files." >&2
  echo "        pre-push checks scan the working tree; only committed" >&2
  echo "        changes are pushed. A green gate against a dirty tree" >&2
  echo "        does not mean the pushed commits pass." >&2
  echo "" >&2
  echo "        commit, stash, or revert before pushing:" >&2
  echo "          git status" >&2
  exit 1
fi

# Collect markdown files once. Excludes node_modules and .git by path,
# the intentionally-malformed validator fixtures (test data, not authored
# prose), and `.context/` (globally-gitignored local-only working notes,
# vault-source snapshots, and research artifacts that never ship).
mapfile -t MD_FILES < <(
  find . -type f -name '*.md' \
    -not -path './node_modules/*' \
    -not -path './.git/*' \
    -not -path './.context/*' \
    -not -path './scripts/__fixtures__/*' \
    -not -path './styles/proselint/*' \
    -not -path './styles/write-good/*' \
    -not -path './styles/.vale-config/*' \
    -not -name 'CHANGELOG.md' \
    | sort
)

if [ ! -d node_modules/js-yaml ]; then
  echo "==> Installing js-yaml@4.1.0 (one-time, cached in node_modules/)"
  npm install --no-save --silent js-yaml@4.1.0
fi

echo "==> Checking markdown wrap (would any file reflow at 120 cols?)"
python3 "$HOME/.claude/md-wrap.py" --check -w 120 "${MD_FILES[@]}"

echo "==> Linting markdown (local .markdownlint-cli2.yaml)"
markdownlint-cli2 "${MD_FILES[@]}"

echo "==> Checking relative-link targets"
node scripts/check-links.mjs

echo "==> Validating principles frontmatter"
node scripts/validate-principles.mjs

echo "==> Running validator regression fixtures"
node scripts/test-validate-principles.mjs

# `last-revised` discipline: bumps must accompany frontmatter changes.
# Resolves the base ref locally; skips when it is not available (e.g.,
# detached push without a fetched origin/dev).
LR_BASE_REF="${BASE_REF:-origin/dev}"
if git rev-parse --verify --quiet "${LR_BASE_REF}" >/dev/null; then
  echo "==> Checking last-revised discipline vs ${LR_BASE_REF}"
  node scripts/check-last-revised.mjs "${LR_BASE_REF}"
  echo "==> Running last-revised checker regression tests"
  node scripts/test-check-last-revised.mjs
else
  echo "==> last-revised check skipped (${LR_BASE_REF} not fetched locally)"
fi

echo "==> Checking release-branch semver (no-op on non-release branches)"
scripts/check-release-version.sh

echo "==> Checking pack-README drift (would any styles/<Pack>/README.md regenerate differently?)"
bun scripts/generate-pack-readme.mjs --check </dev/null

# Shell-script linting — severity threshold "warning" catches real bugs
# (unused vars, quoting issues, missing exits) while ignoring info/style
# noise. Skipped silently when the linter is not on PATH. Install via
# Homebrew (`brew install shellcheck`) or apt (`apt install shellcheck`).
if command -v shellcheck &>/dev/null; then
  echo "==> Running shellcheck (--severity=warning) on tracked shell scripts"
  mapfile -t SHELL_FILES < <({
    git ls-files '*.sh' 2>/dev/null
    git ls-files 'scripts/hooks/*' 2>/dev/null
  } | sort -u)
  if [ ${#SHELL_FILES[@]} -gt 0 ]; then
    shellcheck --severity=warning "${SHELL_FILES[@]}"
  fi
else
  echo "==> Shellcheck skipped (install via \`brew install shellcheck\` or \`apt install shellcheck\`)"
fi

echo "==> Running prose-check (Vale + LanguageTool)"
# Scope to files changed vs PROSE_CHECK_BASE (default origin/dev) so untracked
# or pre-existing prose drift outside the pushed branch's diff can't block the
# push. Full-scope check remains available via `bash scripts/prose-check.sh`.
scripts/prose-check.sh --changed-only </dev/null

echo "==> All pre-push checks passed"
